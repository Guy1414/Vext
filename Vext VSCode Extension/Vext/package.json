{
  "name": "vext",
  "displayName": "Vext Language Support",
  "description": "Language Server Protocol support for the Vext language",
  "publisher": "guy1414",
  "license": "MIT",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./client/out/extension",
  "contributes": {
    "languages": [
      {
        "id": "vext",
        "aliases": [
          "Vext",
          "vext"
        ],
        "extensions": [
          ".vext",
          ".vxt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vext",
        "scopeName": "source.vext",
        "path": "./syntaxes/vext.tmlanguage.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "type",
        "description": "Mapping to int, float, string, etc."
      },
      {
        "id": "function",
        "description": "Mapping to function names"
      },
      {
        "id": "variable",
        "description": "Local variables and parameters"
      },
      {
        "id": "keyword",
        "description": "Control flow keywords"
      },
      {
        "id": "operator",
        "description": "Vext operators like ** or %"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "declaration",
        "description": "Used when defining a new symbol"
      },
      {
        "id": "readonly",
        "description": "For constant values"
      },
      {
        "id": "static",
        "description": "For static members"
      }
    ],
    "commands": [
      {
        "command": "vext.runCode",
        "title": "Run File",
        "category": "Vext",
        "icon": "$(play)"
      },
      {
        "command": "vext.forceUpdateCheck",
        "title": "Check for Updates...",
        "category": "Vext",
        "icon": "$(cloud-download)"
      },
      {
        "command": "vext.openWalkthrough",
        "title": "Open Welcome Guide",
        "category": "Vext",
        "icon": "$(book)"
      },
      {
        "command": "vext.showControlPanel",
        "title": "Show Control Panel",
        "category": "Vext"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vext-explorer",
          "title": "Vext",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "vext-explorer": [
        {
          "id": "vext-info",
          "name": "Project Info"
        },
        {
          "id": "vext-symbols",
          "name": "Outline"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "vext-welcome",
        "title": "Getting Started with Vext",
        "description": "Learn how to write and run Vext code in VS Code.",
        "steps": [
          {
            "id": "install",
            "title": "Compiler Check",
            "description": "Vext automatically downloads the latest compiler for your system. If you see the lightning bolt icon in the status bar, you're ready to go!",
            "media": {
              "markdown": "walkthrough/install.md"
            }
          },
          {
            "id": "run",
            "title": "Your First Run",
            "description": "Open a `.vext` file and click the **Run** icon in the top right. You can also press `Ctrl+Shift+P` and type 'Vext: Run File'.",
            "media": {
              "markdown": "walkthrough/run.md"
            },
            "completionEvents": [
              "onCommand:vext.runCode"
            ]
          }
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vext.runCode",
          "when": "editorLangId == vext",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "vext.runCode",
          "when": "editorLangId == vext"
        },
        {
          "command": "vext.forceUpdateCheck"
        },
        {
          "command": "vext.openWalkthrough"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node build.js",
    "watch": "node build.js --watch",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd .."
  },
  "devDependencies": {
    "@types/node": "^20.5.7",
    "esbuild": "^0.28.0",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
